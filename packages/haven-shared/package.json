{
  "name": "haven-shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types, API contract, and query keys for Haven web and native",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "npx tsup src/index.ts --format cjs,esm --dts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5"
  },
  "peerDependencies": {},
  "files": ["dist"]
}

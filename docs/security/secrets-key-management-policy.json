{
  "schema_version": "1.0.0",
  "artifact_kind": "secrets-key-management-policy",
  "environment_separation": {
    "dev_env_file_path": "backend/.env",
    "prod_secret_manager_required": true,
    "prohibited_repo_files": [
      ".env.production",
      ".env.secret",
      "backend/.env.production",
      "frontend/.env.production"
    ]
  },
  "key_groups": {
    "backend_required": [
      "DATABASE_URL",
      "OPENAI_API_KEY",
      "SECRET_KEY"
    ],
    "billing": [
      "BILLING_STRIPE_WEBHOOK_SECRET"
    ],
    "notification": [
      "RESEND_API_KEY",
      "RESEND_FROM_EMAIL"
    ],
    "ai_router_shared_state": [
      "AI_ROUTER_REDIS_URL"
    ],
    "abuse_guard": [
      "ABUSE_GUARD_STORE_BACKEND",
      "ABUSE_GUARD_REDIS_URL",
      "ABUSE_GUARD_REDIS_KEY_PREFIX"
    ]
  },
  "rotation_policy_days": {
    "backend_required": 90,
    "billing": 90,
    "notification": 90,
    "ai_router_shared_state": 180,
    "abuse_guard": 180
  },
  "incident_response": {
    "revoke_on_leak": true,
    "require_postmortem": true,
    "max_initial_response_minutes": 30
  },
  "references": {
    "security_doc": "SECURITY.md",
    "rotation_runbook": "docs/security/keys.md",
    "backend_env_check": "backend/scripts/check_env.py",
    "encryption_posture": "docs/security/encryption-posture-policy.json"
  }
}

# Localhost runtime source of truth for stable development.
# This file is intentionally tracked and contains no secrets.
#
# Staging / preview / production continue to derive secrets and remote infra
# from deployment env vars plus backend/.env and frontend/.env.local.
# Localhost development should source this file via scripts/local-dev-lib.sh so
# frontend + backend share one unambiguous host/port/DB contract.

HAVEN_LOCAL_DEV_FRONTEND_HOST=127.0.0.1
HAVEN_LOCAL_DEV_FRONTEND_PORT=3000

HAVEN_LOCAL_DEV_BACKEND_HOST=127.0.0.1
HAVEN_LOCAL_DEV_BACKEND_PORT=8000

# Canonical localhost DB mode: local Postgres only.
HAVEN_LOCAL_DEV_DATABASE_MODE=postgres
HAVEN_LOCAL_DEV_POSTGRES_HOST=127.0.0.1
HAVEN_LOCAL_DEV_POSTGRES_PORT=55432
HAVEN_LOCAL_DEV_POSTGRES_DATABASE=haven_local
HAVEN_LOCAL_DEV_POSTGRES_USER=haven
HAVEN_LOCAL_DEV_POSTGRES_PASSWORD=haven_local_dev
HAVEN_LOCAL_DEV_POSTGRES_SERVICE=postgres
HAVEN_LOCAL_DEV_POSTGRES_COMPOSE_PROJECT=haven-local-dev
HAVEN_LOCAL_DEV_POSTGRES_COMPOSE_FILE=config/local-dev-postgres.compose.yml

# Storage remains intentionally remote in localhost development so journal
# attachment contracts stay aligned with staging / production.
HAVEN_LOCAL_DEV_STORAGE_MODE=remote-supabase

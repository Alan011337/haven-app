{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "description": "Haven design tokens — generated from globals.css. Single source of truth: frontend/src/app/globals.css.",
  "color": {
    "background": "0.985 0.005 80",
    "foreground": "0.300 0.010 80",
    "muted": "0.96 0.006 86",
    "muted-foreground": "0.650 0.010 80",
    "card": "0.986 0.004 80",
    "card-foreground": "0.300 0.010 80",
    "popover": "0.986 0.004 80",
    "popover-foreground": "0.300 0.010 80",
    "primary": "0.750 0.080 65",
    "primary-foreground": "0.22 0.01 56",
    "secondary": "0.96 0.006 86",
    "secondary-foreground": "0.300 0.010 80",
    "accent": "0.624 0.028 145",
    "accent-foreground": "0.22 0.01 56",
    "destructive": "0.577 0.245 27.325",
    "destructive-foreground": "0.98 0.005 86",
    "border": "0.92 0.008 86 / 0.12",
    "input": "0.92 0.008 86",
    "ring": "0.750 0.080 65",
    "chart-1": "0.646 0.222 41.116",
    "chart-2": "0.6 0.118 184.704",
    "chart-3": "0.398 0.07 227.392",
    "chart-4": "0.828 0.189 84.429",
    "chart-5": "0.769 0.188 70.08",
    "sidebar": "0.986 0.004 80",
    "sidebar-foreground": "0.300 0.010 80",
    "sidebar-primary": "0.750 0.080 65",
    "sidebar-primary-foreground": "0.22 0.01 56",
    "sidebar-accent": "0.96 0.006 86",
    "sidebar-accent-foreground": "0.300 0.010 80",
    "sidebar-border": "0.92 0.008 86",
    "sidebar-ring": "0.750 0.080 65"
  },
  "radius": {
    "radius": "1.5rem",
    "card": "1.5rem",
    "button": "9999px",
    "input": "1rem",
    "base": "1.5rem"
  },
  "spacing": {
    "page": "1.5rem",
    "section": "1.25rem",
    "block": "0.75rem",
    "stack": "1rem",
    "inline": "0.75rem"
  },
  "shadow": {
    "soft": "0 4px 12px -2px rgb(0 0 0 / 0.06), 0 2px 6px -2px rgb(0 0 0 / 0.04)",
    "lift": "0 20px 40px -10px rgb(214 168 124 / 0.12), 0 8px 16px -4px rgb(0 0 0 / 0.06)",
    "modal": "0 25px 50px -12px rgb(0 0 0 / 0.18)",
    "card": "var(--shadow-soft)",
    "card-hover": "var(--shadow-lift)"
  },
  "typography": {
    "display": "2.25rem",
    "title": "1.5rem",
    "body": "1rem",
    "caption": "0.875rem",
    "h1": "clamp(2.5rem, 4.8vw, 4rem)",
    "h2": "clamp(1.85rem, 3.4vw, 2.7rem)",
    "h3": "1.5rem",
    "section-title": "1.125rem",
    "body-muted": "0.975rem",
    "label": "0.8125rem",
    "micro": "0.6875rem"
  },
  "motion": {
    "ease": {
      "haven": "cubic-bezier(0.32, 0.72, 0, 1)",
      "haven-spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "duration": {
      "haven-fast": "200ms",
      "haven": "220ms",
      "haven-slow": "320ms",
      "haven-ritual": "500ms"
    }
  },
  "font": {
    "mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
    "comment": "font-sans and font-art are set by next/font on <html>."
  }
}

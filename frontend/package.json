{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "predev": "npm run check:env",
    "dev": "next dev --webpack -H 0.0.0.0",
    "dev:turbo": "next dev -H 0.0.0.0",
    "dev:webpack": "next dev --webpack -H 0.0.0.0",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && npm run dev",
    "reinstall": "node -e \"const fs=require('fs'); ['.next','node_modules','package-lock.json'].forEach(p=>{ try { fs.rmSync(p,{recursive:true,force:true}); console.log('Removed',p); } catch(e) {} });\" && npm install",
    "prebuild": "npm run check:env",
    "build": "next build --webpack",
    "prestart": "npm run check:env",
    "start": "next start",
    "lint": "node scripts/lint.mjs && npm run lint:console-error && npm run lint:route-collision && npm run lint:test-imports",
    "lint:console-error": "node scripts/check-no-raw-console-error.mjs",
    "lint:route-collision": "node scripts/check-route-collision.mjs",
    "lint:test-imports": "node scripts/check-test-imports.mjs",
    "typecheck": "node scripts/typecheck.mjs",
    "contract:types:generate": "node scripts/generate-api-contract-types.mjs",
    "contract:types:check": "node scripts/generate-api-contract-types.mjs --check",
    "tokens:generate": "node scripts/generate-design-tokens.mjs",
    "check:env": "node scripts/check-env.mjs",
    "seed:cards": "npx ts-node --esm scripts/seed.ts",
    "seed:cards:dry": "npx ts-node --esm scripts/seed.ts --dry-run",
    "seed:cards:validate": "npx ts-node --esm scripts/seed.ts --validate-only",
    "seed:cards:strict": "npx ts-node --esm scripts/seed.ts --validate-only --strict",
    "seed:cards:qa": "npx ts-node --esm scripts/seed.ts --validate-only --write-report-json --write-clean-json",
    "seed:cards:dry:qa": "npx ts-node --esm scripts/seed.ts --dry-run --write-report-json --write-clean-json",
    "seed:cards:adopt-cleaned": "node scripts/adopt-cleaned.mjs",
    "seed:cards:adopt-cleaned:no-backup": "node scripts/adopt-cleaned.mjs --skip-backup",
    "seed:cards:pipeline": "npm run seed:cards:qa && npm run seed:cards:adopt-cleaned",
    "seed:cards:review": "node scripts/content-review-check.mjs",
    "test": "node scripts/run-test-e2e.mjs",
    "test:unit": "NODE_NO_WARNINGS=1 node --test --experimental-strip-types 'src/**/__tests__/*.test.ts'",
    "test:e2e": "node scripts/run-test-e2e.mjs",
    "test:e2e:raw": "node scripts/check-playwright-browser.mjs && playwright test",
    "test:e2e:auto": "PLAYWRIGHT_AUTO_INSTALL=1 node scripts/run-test-e2e.mjs",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "node scripts/check-playwright-browser.mjs && playwright test e2e/a11y.spec.ts"
  },
  "dependencies": {
    "@lexical/code": "^0.42.0",
    "@lexical/history": "^0.42.0",
    "@lexical/link": "^0.42.0",
    "@lexical/list": "^0.42.0",
    "@lexical/markdown": "^0.42.0",
    "@lexical/react": "^0.42.0",
    "@lexical/rich-text": "^0.42.0",
    "@lexical/selection": "^0.42.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@supabase/supabase-js": "^2.95.3",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "haven-shared": "file:../packages/haven-shared",
    "lexical": "^0.42.0",
    "lucide-react": "^0.563.0",
    "next": "^16.1.6",
    "next-intl": "^4.8.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zustand": "^5.0.11"
  },
  "imports": {
    "#haven/relationship-compass-revision": "./src/features/love-map/relationship-compass-revision.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.24",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
